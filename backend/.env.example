# --- Core ---
# SQLite for v1. Postgres swap: postgresql+asyncpg://user:pass@host:5432/pact_qe
DATABASE_URL=sqlite+aiosqlite:///./pact_qe.db
DEMO_MODE=true

# --- Anthropic (Step 3: agent engine) ---
ANTHROPIC_API_KEY=
REASONING_MODEL=claude-sonnet-4-6
CLASSIFICATION_MODEL=claude-haiku-4-5

# --- Jira (Step 2: real REST adapter; unused while DEMO_MODE=true) ---
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=WLTH
JIRA_BOARD_ID=0
JIRA_JQL_OVERRIDE=
SYNC_ENABLED=false
SYNC_INTERVAL_MINUTES=15

# --- Copado CI/CD (ingest — Phase 1; unused while DEMO_MODE=true) ---
COPADO_ENABLED=false
COPADO_BASE_URL=
COPADO_API_TOKEN=
# Shared secret Copado Functions send as the X-Copado-Signature header.
COPADO_WEBHOOK_SECRET=

# --- GitHub branch ingestion (unused while DEMO_MODE=true) ---
GITHUB_ENABLED=false
GITHUB_API_URL=https://api.github.com
# Fine-grained PAT with contents:read + actions:read on the target repo.
GITHUB_TOKEN=
